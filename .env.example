TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
RUN_MODE=continuous
CHECK_INTERVAL_MINUTES=360

# ScraperAPI key rotation (use SCRAPER_API_KEY_1 / SCRAPER_API_KEY_2 for multi-key rotation)
# Legacy single-key: SCRAPERAPI_KEY=your_key
SCRAPERAPI_KEY=
SCRAPER_API_KEY_1=
SCRAPER_API_KEY_2=
SCRAPER_API_KEY_3=
SCRAPER_API_DUAL_KEY_ENABLED=false
JOB_SEARCH_SEEN_FILE=/data/job_search_seen.json
JOB_SEARCH_APPLIED_FILE=/data/job_search_applied.json
JOB_SEARCH_DISMISSED_FILE=/data/job_search_dismissed.json
JOB_SEARCH_REPORT_PATH=/data/job_search_latest.md
JOB_SEARCH_STATE_FILE=/data/job_search_state.json
JOB_SEARCH_MAX_RESULTS=15
WTTJ_MAX_PAGES=2

# Audit trail for every Applied/Dismissed/Revert status change (job id, old/new status,
# timestamp) — always written, for traceability.
JOB_STATUS_AUDIT_LOG_FILE=/data/job_status_audit.log
