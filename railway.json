{
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "node dist/job-search/run.js",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "cron": {
    "schedule": "0 */3 * * *",
    "command": "npm run jobs:scan"
  }
}